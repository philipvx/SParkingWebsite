# Paksa penggunaan HTTPS (SSL) untuk koneksi aman
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Nonaktifkan indexing direktori untuk mencegah browsing file secara terbuka
Options -Indexes

# Proteksi file database sql dan file konfigurasi sensitif dari akses web langsung
<FilesMatch "\.(sql|db|bak|conf|config|env|ini)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
